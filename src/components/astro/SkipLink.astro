---
/**
 * SkipLink
 *
 * Accessibility skip-to-content link for keyboard users.
 * Visually hidden until focused; allows bypassing repeated navigation.
 * WCAG 2.1 Level A: 2.4.1 Bypass Blocks.
 */
import { getTranslation } from '@i18n/translations';
import type { Locale } from '@type/locale';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props as Props;
const t = getTranslation(locale);
---

<a href="#main-content" class="meta skip-link">
    {t.a11y.skipNavigationLink}
</a>

<style>
    @reference "../../styles/global.css";

    .skip-link {
        @apply sr-only focus:not-sr-only;
        @apply focus:outline-hidden focus:absolute focus:left-2 focus:top-2 focus:z-skip-navigation-link focus:px-2 focus:py-1 focus:ring-4;
        @apply focus:bg-page-bg focus:text-text-primary focus:ring-focus-ring;
    }
</style>
