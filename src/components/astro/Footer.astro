---
import SocialLinks from '@components/astro/SocialLinks.astro';
import { getRoute } from '@config/routes';
import { DEFAULT_LOCALE } from '@i18n/config.ts';
import { getTranslation } from '@i18n/translations';
import type { Locale } from '@type/locale';

export interface Props {
    locale: Locale;
}

const { locale: localeProp } = Astro.props as Partial<Props>;
const locale: Locale = localeProp ?? DEFAULT_LOCALE;
const t = getTranslation(locale);
const currentYear = new Date().getFullYear();
---

<footer>
    <div class="footer-inner">
        <div class="footer-grid">
            <div class="footer-brand">
                <h3>
                    {t.footer.brand}
                    <em>{t.footer.product}</em>
                </h3>

                <p>
                    {t.footer.description}
                </p>
            </div>

            <nav aria-label={t.footer.footerNavAria} class="footer-nav">
                <ul>
                    <li>
                        <a href={getRoute('home', locale)}>
                            {t.nav.home}
                        </a>
                    </li>

                    <li>
                        <a href={getRoute('news', locale)}>
                            {t.nav.news}
                        </a>
                    </li>

                    <li>
                        <a href={getRoute('projects', locale)}>
                            {t.nav.projects}
                        </a>
                    </li>
                </ul>
            </nav>

            <nav aria-label={t.footer.socialLinksAria} class="footer-social">
                <h4>
                    {t.footer.followAmbilab}
                </h4>

                <SocialLinks {locale} />
            </nav>
        </div>

        <div class="footer-copyright">
            {t.footer.copyright} © {currentYear}
            {t.footer.brand}. {t.footer.allRightsReserved}.
        </div>
    </div>
</footer>

<style>
    @reference "../../styles/global.css";

    footer {
        @apply select-none border-t-2;
        @apply border-page-bg bg-footer-bg text-footer-text;

        padding-bottom: var(--cookie-banner-height, 0px);
    }

    @media (min-width: 640px) {
        footer {
            padding-bottom: var(--cookie-banner-height-sm, 0px);
        }
    }

    @media (min-width: 768px) {
        footer {
            padding-bottom: var(--cookie-banner-height-md, 0px);
        }
    }

    .footer-inner {
        @apply container mx-auto px-4 pb-[18px] pt-5;
        @apply sm:max-w-[640px] sm:pb-7 sm:pt-[26px];
        @apply md:max-w-[768px] md:pb-[34px] md:pt-[54px];
        @apply lg:max-w-[928px];
    }

    .footer-grid {
        @apply grid grid-cols-1 gap-4;
        @apply md:grid-cols-3;
    }

    .footer-brand {
        @apply md:-my-6;

        & h3 {
            @apply compact-heading -ml-px mb-1 text-nowrap;

            & em {
                @apply font-light not-italic text-lime-500;
            }
        }

        & p {
            @apply meta -ml-px text-balance;
        }
    }

    .footer-nav {
        @apply meta -ml-px;

        & ul {
            @apply flex flex-col;
            @apply md:flex-wrap md:pt-[5px];
        }
    }

    .footer-social {
        @apply meta;

        & h4 {
            @apply -ml-px mb-0.5;
            @apply md:mt-[5px];
        }
    }

    .footer-copyright {
        @apply meta -ml-px mt-[18px];
    }
</style>
