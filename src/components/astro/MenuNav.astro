---
import { getRoute, isRouteActive, PAGE_SLUGS } from '@config/routes';
import { getTranslation } from '@i18n/translations';
import type { Locale } from '@type/locale';
import type { LocaleContent } from '@utils/content-loader';

export interface Props {
    locale: Locale;
    currentPath: string;
    mobile: boolean;
    pageMap?: LocaleContent['pageMap'] | undefined;
}

const { locale, currentPath, mobile, pageMap } = Astro.props as Props;

const t = getTranslation(locale);

const getPageTitle = (slug: string): string | undefined => {
    const page = pageMap?.get(slug);

    return page?.data.menuTitle ?? page?.data.title;
};

const navItems = [
    {
        href: getRoute('home', locale),
        label: getPageTitle(PAGE_SLUGS.home[locale]) ?? t.nav.home,
        isActive: isRouteActive(currentPath, 'home'),
    },

    {
        href: getRoute('news', locale),
        label: getPageTitle(PAGE_SLUGS.news[locale]) ?? t.nav.news,
        isActive: isRouteActive(currentPath, 'news'),
    },

    {
        href: getRoute('projects', locale),
        label: getPageTitle(PAGE_SLUGS.projects[locale]) ?? t.nav.projects,
        isActive: isRouteActive(currentPath, 'projects'),
    },
];
---

{
    mobile ? (
        <div class="nav-mobile">
            {navItems.map((item) => (
                <a href={item.href} aria-current={item.isActive ? 'page' : undefined}>
                    {item.label}
                </a>
            ))}
        </div>
    ) : (
        <div class="nav-desktop">
            {navItems.map((item) => (
                <a href={item.href} aria-current={item.isActive ? 'page' : undefined}>
                    {item.label}
                </a>
            ))}
        </div>
    )
}

<style>
    @reference '../../styles/global.css';

    .nav-mobile {
        @apply flex w-full flex-col;
    }

    .nav-desktop {
        @apply flex items-center;
    }

    .nav-mobile a,
    .nav-desktop a {
        @apply meta px-2 py-[6px];
        @apply text-text-secondary;
        @apply hover:bg-active hover:text-text-primary;
        @apply focus-visible:bg-active focus-visible:text-text-primary;

        &[aria-current='page'] {
            @apply bg-text-primary text-page-bg;
        }
    }
</style>
