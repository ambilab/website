---
/**
 * E2E fixture page for GoToTop component.
 *
 * Renders GoToTop with forceVisible and client:load so the button is always
 * visible and hydrated, enabling deterministic E2E tests for aria-hidden on the SVG.
 */

import '@/styles/global.css';

import Head from '@components/astro/Head.astro';
import GoToTopComponent from '@components/svelte/GoToTop.svelte';
import { DEFAULT_LOCALE } from '@i18n/config';
import type { Locale } from '@type/locale';

const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const permalink = `${Astro.url.origin}/e2e/go-to-top`;
---

<!doctype html>
<html lang={locale}>
    <head>
        <Head
            title="E2E GoToTop fixture"
            description="Deterministic fixture for GoToTop aria-hidden E2E tests"
            permalink={permalink}
            locale={locale}
        />
    </head>

    <body class="flex min-h-screen flex-col bg-page-bg text-text-primary">
        <main id="main-content" class="flex-1">
            <p>GoToTop fixture for E2E tests</p>
        </main>

        <GoToTopComponent client:load locale={locale} forceVisible={true} />
    </body>
</html>
